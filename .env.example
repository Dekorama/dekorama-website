# Copia a .env.local y rellena con tus valores.
# Brevo: https://www.brevo.com/ → API Keys
BREVO_API_KEY=tu_api_key_de_brevo
BREVO_SENDER_EMAIL=admin@dekoramagroup.com
BREVO_SENDER_NAME=Dekorama Web

# URL pública del sitio (para sitemap.xml y robots.txt)
NEXT_PUBLIC_SITE_URL=https://www.dekoramagroup.com

# Google Tag Manager (opcional; por defecto GTM-5HRSQRQK)
# NEXT_PUBLIC_GTM_ID=GTM-5HRSQRQK

# Google Analytics GA4 (opcional; por defecto G-XDYCVSTQZG)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XDYCVSTQZG

# ============================================================
# SEO Content Pipeline
# ============================================================

# [REQUIRED] Google Gemini Flash — article + cover image generation
# Free API key at: https://aistudio.google.com
GEMINI_API_KEY=tu_api_key_de_gemini_aqui
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# [OPTIONAL] Google Search Console — automated keyword research
# Without this, add keywords manually to scripts/keywords-queue.json instead.
# Setup:
#   1. Create a service account in Google Cloud Console
#   2. Add it as a Viewer in Search Console → Settings → Users and permissions
#   3. Download the JSON key and base64-encode it:
#      base64 -i service-account.json | tr -d "\n"
GOOGLE_SERVICE_ACCOUNT_JSON=key_base64_encoded_aqui
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://www.dekoramagroup.com

# [OPTIONAL] Google Indexing API — fast URL submission after publishing
# Without this, Google finds new posts via sitemap (may take a few days).
# Uses the same service account as above, but the account must be OWNER
# in Search Console (not just Viewer).
# No extra key needed — already covered by GOOGLE_SERVICE_ACCOUNT_JSON above.
